<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#265BB5FF"/>
            <stroke android:width="1dp" android:color="@color/blue_border_20"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/blue_bg_06"/>
            <stroke android:width="1dp" android:color="@color/blue_border_20"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
</selector>
