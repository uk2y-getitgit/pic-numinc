<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#33FF3B3B"/>
            <stroke android:width="1dp" android:color="@color/red_border_30"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape>
            <solid android:color="#0AFF3B3B"/>
            <stroke android:width="1dp" android:color="#1FFF3B3B"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/red_bg_12"/>
            <stroke android:width="1dp" android:color="@color/red_border_30"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</selector>
