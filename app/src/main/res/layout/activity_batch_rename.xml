<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- ── 앱 헤더 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <!-- 뒤로가기 버튼 -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="@color/text_dim"
            android:textSize="18sp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:stateListAnimator="@null" />

        <!-- 앱명 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋  사진 일괄 변환"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="폴더 내 사진 이름 일괄 변경"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- 탭 뱃지 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="일괄변환"
            android:textColor="@color/purple_lt"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_btn_batch" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- ── 스크롤 본문 ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="16dp">

            <!-- ── 1. 변환할 폴더 선택 카드 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="11dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="10dp"
                        android:background="@color/purple" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📁  변환할 폴더 선택"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_marginStart="5dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvBatchFolder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="폴더 미선택"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:singleLine="true"
                    android:ellipsize="start"
                    android:padding="10dp"
                    android:background="@drawable/bg_surface_box"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btnSelectBatchFolder"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="📂  갤러리에서 폴더 선택"
                    android:textColor="@color/purple_lt"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_batch"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="7dp"
                    android:layout_marginBottom="13dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- ── 2. 발견된 파일 목록 카드 (폴더 선택 후 표시) ── -->
            <LinearLayout
                android:id="@+id/cardFileList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="11dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="10dp"
                        android:background="@color/green" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🖼️  발견된 사진 목록"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_marginStart="5dp" />
                </LinearLayout>

                <!-- 파일 수 / 날짜 범위 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/tvFileCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="발견된 이미지: 0개"
                        android:textColor="@color/green"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvDateRange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_dim"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="6dp" />

                <!-- 파일명 목록 (동적으로 추가) -->
                <LinearLayout
                    android:id="@+id/llFileList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_surface_box"
                    android:padding="10dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginBottom="13dp" />

            </LinearLayout>

            <!-- ── 3. 변환 설정 카드 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="11dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="10dp"
                        android:background="@color/purple" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏗️  변환 설정"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_marginStart="5dp" />
                </LinearLayout>

                <!-- 현장명 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="현장명"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:background="@color/white_03" />
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/border" />
                    <EditText
                        android:id="@+id/etBatchSiteName"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="예) 현장명 (선택)"
                        android:textColorHint="@color/text_dim"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="4dp"
                        android:background="@null"
                        android:inputType="text"
                        android:maxLines="1" />
                    <Button
                        android:id="@+id/btnClearBatchSite"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="✕"
                        android:textColor="@color/text_dim"
                        android:textSize="12sp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- 접두어 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="접두어"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:background="@color/white_03" />
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/border" />
                    <EditText
                        android:id="@+id/etBatchPrefix"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="예) 결함, 외벽"
                        android:textColorHint="@color/text_dim"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="4dp"
                        android:background="@null"
                        android:inputType="text"
                        android:maxLines="1" />
                    <Button
                        android:id="@+id/btnClearBatchPrefix"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="✕"
                        android:textColor="@color/text_dim"
                        android:textSize="12sp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- 시작번호 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="13dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="시작번호"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:background="@color/white_03" />
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/border" />
                    <EditText
                        android:id="@+id/etStartNumber"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="기본값: 1"
                        android:text="1"
                        android:textColorHint="@color/text_dim"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:background="@null"
                        android:inputType="number"
                        android:maxLines="1" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── 4. 변환 결과 미리보기 카드 ── -->
            <LinearLayout
                android:id="@+id/cardPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_batch_card"
                android:layout_marginBottom="11dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="10dp"
                        android:background="@color/purple" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👁️  변환 결과 미리보기 (처음 5개)"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_marginStart="5dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llPreviewList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_surface_box"
                    android:padding="10dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="13dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- ── 일괄 변환 버튼 ── -->
    <Button
        android:id="@+id/btnConvert"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="📋  일괄 변환 시작"
        android:textColor="@color/purple_lt"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_batch"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:enabled="false"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:stateListAnimator="@null" />

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- ── 하단 네비게이션 바 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@color/surface">

        <!-- 홈 탭 -->
        <LinearLayout
            android:id="@+id/navTabHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="20sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="홈"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- 세로 구분선 -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/border" />

        <!-- 일괄변환 탭 (현재 활성) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/purple_bg_05">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="20sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="일괄변환"
                android:textColor="@color/purple_lt"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
