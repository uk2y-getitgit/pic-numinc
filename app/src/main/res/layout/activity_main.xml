<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- ── 앱 헤더 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <!-- 앱명 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📸 Smart Field Snap"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="현장사진 자동 이름변경"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- 서비스 상태 뱃지 -->
        <TextView
            android:id="@+id/tvServiceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● 대기 중"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/bg_status_inactive" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- ── 스크롤 본문 ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <!-- ── 1. 감시 폴더 선택 카드 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="11dp">

                <!-- 카드 라벨 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="10dp"
                        android:background="@color/orange" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📁  감시 폴더 선택"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_marginStart="5dp" />
                </LinearLayout>

                <!-- 폴더 경로 표시 -->
                <TextView
                    android:id="@+id/tvSelectedFolder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="폴더 미선택 — 기본 카메라(DCIM) 감시"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:singleLine="true"
                    android:ellipsize="start"
                    android:padding="10dp"
                    android:background="@drawable/bg_surface_box"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="8dp" />

                <!-- 폴더 선택 버튼 -->
                <Button
                    android:id="@+id/btnSelectFolder"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="📂  폴더 선택"
                    android:textColor="@color/blue_lt"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_folder"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="7dp"
                    android:layout_marginBottom="13dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- ── 2. 현장 정보 입력 카드 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="11dp">

                <!-- 카드 라벨 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="10dp"
                        android:background="@color/orange" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏗️  현장 정보 입력"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_marginStart="5dp" />
                </LinearLayout>

                <!-- 현장명 입력 필드 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="현장명"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:background="@color/white_03" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/border" />

                    <EditText
                        android:id="@+id/etSiteName"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="예) A현장, 강남OO빌딩"
                        android:textColorHint="@color/text_dim"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="4dp"
                        android:background="@null"
                        android:inputType="text"
                        android:maxLines="1" />

                    <Button
                        android:id="@+id/btnClearSite"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="✕"
                        android:textColor="@color/text_dim"
                        android:textSize="12sp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- 접두어 입력 필드 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="13dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="접두어"
                        android:textColor="@color/text_dim"
                        android:textSize="11sp"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:background="@color/white_03" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/border" />

                    <EditText
                        android:id="@+id/etPrefix"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="예) 외벽점검, img"
                        android:textColorHint="@color/text_dim"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="4dp"
                        android:background="@null"
                        android:inputType="text"
                        android:maxLines="1" />

                    <Button
                        android:id="@+id/btnClearPrefix"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="✕"
                        android:textColor="@color/text_dim"
                        android:textSize="12sp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── 3. 파일명 미리보기 카드 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_preview_card"
                android:layout_marginBottom="11dp">

                <!-- 카드 라벨 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="10dp"
                        android:background="@color/orange" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👁️  파일명 미리보기"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_marginStart="5dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="다음 촬영 사진에 적용될 파일명"
                    android:textColor="@color/text_dim"
                    android:textSize="10sp"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="6dp" />

                <!-- 미리보기 파일명 -->
                <TextView
                    android:id="@+id/tvPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="img-001.jpg"
                    android:textColor="@color/orange_lt"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:padding="11dp"
                    android:background="@drawable/bg_surface_box"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="6dp" />

                <!-- 구성요소 칩 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/chipSite"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="현장명"
                        android:textColor="@color/orange_lt"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="@drawable/bg_chip_site"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:id="@+id/chipPre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="접두어"
                        android:textColor="#3DD68C"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="@drawable/bg_chip_pre"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:id="@+id/chipNum"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="001"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="@drawable/bg_chip_num"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=".jpg"
                        android:textColor="@color/yellow"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="@drawable/bg_chip_ext" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── 4. 번호 카운터 카드 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="11dp">

                <!-- 카드 라벨 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="10dp"
                        android:background="@color/orange" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔢  촬영 번호"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_marginStart="5dp" />
                </LinearLayout>

                <!-- 카운터 숫자 + 초기화 버튼 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="13dp">

                    <!-- 숫자 + 단위 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <TextView
                            android:id="@+id/tvCurrentCounter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="001"
                            android:textColor="@color/orange"
                            android:textSize="40sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:lineSpacingMultiplier="1.0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="번째 사진"
                            android:textColor="@color/text_dim"
                            android:textSize="12sp"
                            android:layout_marginStart="5dp"
                            android:layout_marginBottom="6dp" />
                    </LinearLayout>

                    <!-- 초기화 버튼 -->
                    <Button
                        android:id="@+id/btnResetCounter"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="🔄  번호 초기화"
                        android:textColor="@color/yellow"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_btn_reset"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── 5. 서비스 시작 / 중지 버튼 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- 시작 버튼 -->
                <Button
                    android:id="@+id/btnStartService"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:text="▶  서비스 시작"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_start"
                    android:layout_marginEnd="5dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null" />

                <!-- 중지 버튼 -->
                <Button
                    android:id="@+id/btnStopService"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:text="■  서비스 중지"
                    android:textColor="@color/red_accent"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_stop"
                    android:layout_marginStart="5dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- ── 6. 현장명 폴더 정리 카드 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="14dp">

                <!-- 카드 라벨 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="10dp"
                        android:background="@color/teal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗂️  현장명 폴더 정리"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_marginStart="5dp" />
                </LinearLayout>

                <!-- 설명 텍스트 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="현재 입력된 현장명으로 시작하는 사진을\n폴더를 생성하여 자동으로 이동합니다"
                    android:textColor="@color/text_dim"
                    android:textSize="10sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="8dp" />

                <!-- 정리 버튼 -->
                <Button
                    android:id="@+id/btnOrganizeFolder"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="🗂️  현장명 폴더 생성 / 정리"
                    android:textColor="@color/teal_lt"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_organize"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="13dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- ── 하단 힌트 ── -->
            <TextView
                android:id="@+id/tvBottomHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="서비스 시작 후 카메라 앱으로 촬영하면\n파일명이 자동으로 변경됩니다"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.6" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
